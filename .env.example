# Server
PORT=3000
NODE_ENV=development
TZ=Asia/Ho_Chi_Minh

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# Redis (Upstash)
REDIS_URL=rediss://default:token@xxx.upstash.io:6379

# Scheduler defaults
SCHEDULE_DEFAULT_MAX_RETRIES=3
SCHEDULE_DEFAULT_TIMEOUT_MS=30000
IDEMPOTENCY_TTL_HOURS=24

# Set true to enable smoke e2e tests (requires real Neon + Upstash in .env)
# SMOKE_TEST=true

# File tasks
FILE_TASK_BASE_PATH=./data

# Email (mock by default)
EMAIL_MODE=mock
# EMAIL_MODE=smtp
# SMTP_HOST=smtp.mailtrap.io
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@internal.local
